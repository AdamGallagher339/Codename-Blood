# Backend environment variables
# Copy this file to .env and fill in values.

# AWS Cognito
AWS_REGION=
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=

# Auth mode (optional)
# - default: Cognito
# - set AUTH_MODE=local to use local dev auth (mints simple JWTs)
AUTH_MODE=
LOCAL_AUTH=

# Local auth (dev-only)
LOCAL_AUTH_SECRET=

# DynamoDB tables (main backend)
USERS_TABLE=
BIKES_TABLE=
DEPOTS_TABLE=
JOBS_TABLE=

# DynamoDB tables (fleet tracker)
FLEET_BIKES_TABLE=
FLEET_SERVICE_TABLE=

# DynamoDB tables (lambda)
MOTORCYCLES_TABLE=

# Optional (if you later add more features)
# COGNITO_DOMAIN=
