# Backend environment variables
# Copy this file to .env and fill in values.

# AWS Cognito
AWS_REGION=eu-north-1
COGNITO_USER_POOL_ID=eu-north-1_y5Gy1g6mo
COGNITO_CLIENT_ID=1e6pvf3qni2oa40q10pubpe38
COGNITO_CLIENT_SECRET=

# Auth mode (optional)
# - default: Cognito
# - set AUTH_MODE=local to use local dev auth (mints simple JWTs)
AUTH_MODE=
LOCAL_AUTH=

# Local auth (dev-only)
LOCAL_AUTH_SECRET=

# Optional app config table (key/value env store)
# If set, backend startup will pull envs from this DynamoDB table and overlay local .env values.
APP_CONFIG_ENABLED=true
APP_CONFIG_TABLE=AppConfig

# DynamoDB tables (main backend)
USERS_TABLE=
BIKES_TABLE=
DEPOTS_TABLE=
JOBS_TABLE=
APPLICATIONS_TABLE=

# DynamoDB tables (fleet tracker)
FLEET_BIKES_TABLE=
FLEET_SERVICE_TABLE=

# DynamoDB tables (lambda)
MOTORCYCLES_TABLE=

# Web Push (VAPID) – generate with: npx web-push generate-vapid-keys --json
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CONTACT=mailto:admin@bloodbike.app

# Optional (if you later add more features)
# COGNITO_DOMAIN=
